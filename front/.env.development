# Same-origin API during Vite dev: browser calls /api/v1/... → Vite proxies to DEV_API_PROXY_TARGET (vite.config.js).
VITE_API_BASE_URL=/api/v1

# Local Laravel — must match routes in this repo (includes POST /expense-categories).
# Run from `back/`: php artisan serve  → http://127.0.0.1:8000
# Restart Vite after changing this file.
DEV_API_PROXY_TARGET=https://back.crm-amazonltd.live/

# Remote CRM API may return 405 on POST /expense-categories if that deployment is older than this codebase.
# DEV_API_PROXY_TARGET=https://back.crm-amazonltd.live

# XAMPP example (same Laravel app):
# DEV_API_PROXY_TARGET=http://localhost/Amazon-Marine-System/back/public/
