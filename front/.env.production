VITE_API_BASE_URL=https://back.crm-amazonltd.live/api/v1

# If you upload the whole "front" folder, uncomment ONE line that matches your public URL, then npm run build:
# Site root is the "front" folder itself → VITE_BASE_PATH=/dist/
# Site is http://localhost/Project/front/ with htdocs as root → VITE_BASE_PATH=/Project/front/dist/
